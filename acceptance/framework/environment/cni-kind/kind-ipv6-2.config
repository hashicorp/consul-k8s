# dc2 cluster – IPv6 pod subnet fd00:10:245::/64 (non-overlapping with dc1's fd00:10:244::/64)
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  ipFamily: "ipv6"
  # Calico's IPAM pool – must match custom-resources-ipv6-2.yaml.
  podSubnet: "fd00:10:245::/64"
  serviceSubnet: "fd00:10:97::/112"
  # The default kind.net CNI plugin will not be installed
  disableDefaultCNI: true
nodes:
- role: control-plane
