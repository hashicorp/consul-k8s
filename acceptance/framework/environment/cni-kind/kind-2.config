# dc2 cluster – pod subnet 192.169.0.0/16 (non-overlapping with dc1's 192.168.0.0/16)
# Calico assigns /26 host-routes from the /16 pool. Each cluster must use a
# distinct /16 so that flat-network routing between clusters is unambiguous.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  ipFamily: "ipv4"
  podSubnet: 192.169.0.0/16
  serviceSubnet: 10.111.0.0/16
  # The default kind.net CNI plugin will not be installed
  disableDefaultCNI: true
nodes:
- role: control-plane
