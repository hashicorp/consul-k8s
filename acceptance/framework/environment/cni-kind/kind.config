# dc1 cluster – pod subnet 192.168.0.0/16
# Each additional cluster (dc2/dc3/dc4) must use a DIFFERENT /16 pod subnet
# (kind-2.config / kind-3.config / kind-4.config) so that flat-network routing
# between clusters is unambiguous.  Calico assigns /26 host-routes within the
# /16 pool; if two clusters share the same pool their /26 routes conflict and
# cross-cluster traffic is silently delivered to the wrong local pod.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  ipFamily: "ipv4"
  # Calico's default subnet. Needed for Calico to run on kind.
  podSubnet: 192.168.0.0/16
  serviceSubnet: 10.110.0.0/16
  # The default kind.net CNI plugin will not be installed
  disableDefaultCNI: true
nodes:
- role: control-plane
