# dc1 cluster – IPv6 pod subnet fd00:10:244::/64
# Each additional cluster must use a DIFFERENT pod subnet; see kind-ipv6-2.config
# through kind-ipv6-4.config. Sharing the same pool causes cross-cluster routing
# to be ambiguous (Calico host-routes take precedence over the flat-network route).
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  ipFamily: "ipv6"
  # Calico's default subnet. Needed for Calico to run on kind.
  podSubnet: "fd00:10:244::/64"
  serviceSubnet: "fd00:10:96::/112"
  # The default kind.net CNI plugin will not be installed
  disableDefaultCNI: true
nodes:
- role: control-plane
