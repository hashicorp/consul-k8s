# dc1 cluster – explicit pod subnet so all four clusters (dc1–dc4) use
# non-overlapping ranges (10.244–10.247).  Without this, Kind defaults every
# cluster to 10.244.0.0/16 which makes flat-network routing for mesh-gateway
# mode 'none' ambiguous.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  ipFamily: "ipv4"
  podSubnet: 10.244.0.0/16
  serviceSubnet: 10.96.0.0/16
nodes:
- role: control-plane